# Google AI Studio key — get it at https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=your_google_ai_studio_key_here

# Path to your Obsidian vault (relative to project root, or absolute)
VAULT_PATH=./vault

# Ollama model to use when running with --model ollama
# Best for 6GB VRAM: qwen2.5:7b-instruct-q4_K_M (~4.5GB)
# Fallback for less VRAM: llama3.2:3b (~3GB)
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
