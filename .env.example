# ── Model backend ──────────────────────────────────────────────────────────
# Choose: openrouter | gemini | ollama
MODEL_BACKEND=openrouter

# ── OpenRouter (cloud, no regional blocks) ─────────────────────────────────
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── Gemini (cloud) ─────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=your_gemini_api_key_here

# ── Ollama (local) ─────────────────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_BASE_URL=http://localhost:localhost:11434

# ── Vault ──────────────────────────────────────────────────────────────────
# Absolute path to your Obsidian vault folder
VAULT_PATH=./vault

SAVE_INDEX_PATH=path_to_faiss_base

# ── Embeddings (local, no API needed) ──────────────────────────────────────
# Model is downloaded automatically on first run (~120 MB)
# Good multilingual (RU/EN) default: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
